<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <record id="module_category_field_operation" model="ir.module.category">
            <field name="name">Field Operation</field>
            <field name="sequence">20</field>
        </record>

        <record id="group_field_worker" model="res.groups">
            <field name="name">Worker</field>
            <field name="category_id" ref="module_category_field_operation"/>
        </record>

        <record id="group_field_dispatcher" model="res.groups">
            <field name="name">Dispatcher</field>
            <field name="category_id" ref="module_category_field_operation"/>
            <field name="implied_ids" eval="[(4, ref('group_field_worker'))]"/>
        </record>

        <record id="group_field_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="category_id" ref="module_category_field_operation"/>
            <field name="implied_ids" eval="[(4, ref('group_field_dispatcher'))]"/>
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
        </record>

        <record id="field_operation_rule_worker" model="ir.rule">
            <field name="name">Field Operation: workers see only their own</field>
            <field name="model_id" ref="model_field_operation"/>
            <field name="domain_force">[('worker_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_field_worker'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <record id="field_operation_rule_dispatcher" model="ir.rule">
            <field name="name">Field Operation: dispatchers see all</field>
            <field name="model_id" ref="model_field_operation"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_field_dispatcher'))]"/>
        </record>

    </data>
</odoo>
